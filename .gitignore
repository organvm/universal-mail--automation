# Secrets
credentials.json
token.pickle
client_secret_*.json

# Runtime env files for deploys (provider/Stripe credentials) — never commit.
# DEPLOY.md / scripts/deploy.sh pass these to the container via --env-file.
prod.env
*.env
!*.env.example

# Local protected-sender list (PII: real lawyer/banks/gov/self) — never commit.
# Use config/protected_senders.example.txt as the template.
config/protected_senders.local.txt

# Logs
*.log
gmail_labeler.log

# Triage audit receipts (PII: real sender addresses) — never commit.
# audit/README.md documents the format and is tracked; the receipts are not.
audit/*.jsonl

# Durable app store (Stripe customer ids, api keys, receipt ledger) — never commit.
data/
*.db
*.db-wal
*.db-shm

# Python
__pycache__/
*.py[cod]
.venv/
env/
venv/
.DS_Store

# Local Claude Code settings (personal permission rules) — never commit.
.claude/settings.local.json

# Local agent/session state — contains transcripts, prompts, and private context.
.claude/sessions/
.claude/worktrees/
.serena/
